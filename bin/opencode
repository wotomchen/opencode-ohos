#!/bin/sh
# This script uses the bundled Node.js binary (node/node) first,
# and falls back to system node if the bundled one is missing.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Use bundled node first
NODE_BIN="$INSTALL_DIR/node/node"
if [ ! -x "$NODE_BIN" ]; then
  NODE_BIN="$(command -v node 2>/dev/null || echo '')"
fi

if [ ! -x "$NODE_BIN" ]; then
  echo "Error: cannot find node executable" >&2
  exit 1
fi

export OPENCODE_UI_DIR="${OPENCODE_UI_DIR:-$INSTALL_DIR/web-ui}"
exec "$NODE_BIN" "$INSTALL_DIR/index.mjs" "$@"
