#!/bin/sh
# OpenCode for HarmonyOS — startup script
#
# Usage:
#   ~/.opencode/bin/opencode [args...]
#
# Set OPENCODE_UI_DIR to point to the bundled web app
export OPENCODE_UI_DIR="${OPENCODE_UI_DIR:-$HOME/.opencode/web-ui}"
export HOME="${HOME:-$HOME}"
export PATH="$PATH:/bin"

# 解析 node-22 路径
NODE_BIN=""
if [ -f "$HOME/.zshrc" ]; then
  # 加载 .zshrc 获取 alias 定义，然后查找 node-22
  eval "$(grep '^alias node-22=' "$HOME/.zshrc" 2>/dev/null)" 2>/dev/null
  NODE_BIN="$(command -v node-22 2>/dev/null || command -v node 2>/dev/null || echo '')"
fi
# 如果还是找不到，直接探测已知路径
if [ -z "$NODE_BIN" ] || [ ! -x "$NODE_BIN" ]; then
  for candidate in "/storage/Users/currentUser/app/node.org/node_22.7.0/bin/node" "$HOME/app/node.org/node_22.7.0/bin/node" "/data/service/hnp/bin/node"; do
    if [ -x "$candidate" ]; then
      NODE_BIN="$candidate"
      break
    fi
  done
fi
if [ ! -x "$NODE_BIN" ]; then
  echo "Error: cannot find node executable" >&2
  exit 1
fi

exec "$NODE_BIN" "$HOME/.opencode/index.mjs" "$@"
